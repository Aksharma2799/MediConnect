# Backend Configuration

# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://admin:password123@localhost:27017/mediconnect?authSource=admin
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_12345
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Email Service (SendGrid)
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@mediconnect.com
SENDGRID_FROM_NAME=MediConnect

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_key_12345
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
