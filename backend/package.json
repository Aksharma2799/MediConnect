  "version": "1.0.0",
  "description": "MediConnect Healthcare Platform API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
