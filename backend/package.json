    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.4",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "winston": "^3.10.0",
    "joi": "^17.10.0",
    "redis": "^4.6.10",
    "socket.io": "^4.5.4",
    "bull": "^4.11.4",
    "razorpay": "^2.8.5",
    "axios": "^1.5.0",
    "express-rate-limit": "^7.0.0",
    "validator": "^13.11.0",
